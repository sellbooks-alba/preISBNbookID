# eBay Developer account -> https://developer.ebay.com/my/keys (production keys)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# eBay Marketplace Account Deletion notification endpoint (required by eBay
# for every dev account). Pick your own token, 32-80 chars, letters/digits/
# underscore/hyphen. EBAY_NOTIFICATION_ENDPOINT_URL must be the EXACT public
# HTTPS URL you register in the eBay Developer Portal, character for
# character. See app.py's /ebay/account-deletion route.
EBAY_VERIFICATION_TOKEN=
EBAY_NOTIFICATION_ENDPOINT_URL=

# Optional — only needed for the LLM-vision extraction backend (src/extract.py)
ANTHROPIC_API_KEY=

# Keepa API -> https://keepa.com/#!api
KEEPA_API_KEY=
